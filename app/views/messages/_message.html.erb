<div class="chat_message">
    <div class="chat_user_time">
      <div class="chat_user_name">
        <%= message.user.name %>
      </div>
      <div class="chat_time">
        <%= l message.created_at %>
      </div>
    </div>
    <div class="chat_text">
      <%= message.content %>
    </div>
    <%= image_tag message.image.variant(resize: '500x500'), class: 'message-image' if message.image.attached? %>
  </div>